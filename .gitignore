# Build artifacts
out/
*.o
*.d
*.elf
*.map
*.bin

# Logs debug
/tmp/kdebug-*.log
/tmp/gdb-proxy.pid

# Environnement local (généré par setup.sh)
*.local.sh

# VS Code local (settings machine-specific)
.vscode/settings.local.json

# Rust build artifacts. The leading `/` anchors this to the repo root and
# subdirectory `target/` (e.g. mds-mcp/target/) so that source folders named
# `target` (mds-mcp/src/target/) aren't accidentally excluded.
/target/
/*/target/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# VS Code extension build artifacts
extensions/**/node_modules/
extensions/**/dist/
extensions/**/*.vsix

# Vendored deps build outputs
vendor/*/build/
vendor/*/build_release/
vendor/clownmdemu-libretro/*.so
vendor/clownmdemu-libretro/*.o

# M0 spike host tools
tools/dump_vram
tools/*.o
vram*.bin
